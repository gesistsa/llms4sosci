#!/bin/bash
set -euo pipefail

QUARTO_VERSION=1.8.27
QUARTO_TGZ="quarto-${QUARTO_VERSION}-linux-amd64.tar.gz"
QUARTO_URL="https://github.com/quarto-dev/quarto-cli/releases/download/v${QUARTO_VERSION}/${QUARTO_TGZ}"

curl -fsSL "${QUARTO_URL}" -o "/tmp/${QUARTO_TGZ}"
tar -C /usr/local -xzf "/tmp/${QUARTO_TGZ}"
ln -sfn "/usr/local/quarto-${QUARTO_VERSION}/bin/quarto" /usr/local/bin/quarto
rm -f "/tmp/${QUARTO_TGZ}"

quarto --version
R --version
quarto render LLM_API_V1.qmd